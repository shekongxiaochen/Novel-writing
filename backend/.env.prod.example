# ===== 生产环境变量模板 =====
# 用法：复制为 .env.prod，填入你自己的强随机值，然后：
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d
#
# 生成强随机值：
#   openssl rand -hex 48          # 生成 JWT_SECRET
#   openssl rand -base64 24       # 生成数据库/管理员密码
#
# ⚠️ 本文件是模板，下面全是占位符，必须替换为你自己的值后再部署。
# ⚠️ .env.prod 含真实密钥，切勿提交到 git（已被 .gitignore 覆盖）。
# ⚠️ 切勿把真实密钥写进本模板文件（.env.prod.example 会被提交到仓库）。

# 数据库 root 密码（容器内部使用，不对外暴露端口）
MYSQL_ROOT_PASSWORD=<在此填入 openssl rand -base64 24 生成的值>

# JWT 签名密钥（轮换后所有用户需重新登录）
JWT_SECRET=<在此填入 openssl rand -hex 48 生成的值>

# CORS：填你的正式域名（Tauri 客户端用 tauri:// 协议，通常无需 CORS；
# 若有 Web 版前端，填其域名。多个用逗号分隔，绝不要用 *）
CORS_ORIGINS=https://your-domain.com

# 管理后台
ADMIN_ENABLED=true
ADMIN_USERNAME=admin
ADMIN_PASSWORD=<在此填入 openssl rand -base64 24 生成的值>
# 首次启动设为 true（把上面密码写入数据库），成功登录一次后改为 false 再重启
ADMIN_SYNC_PASSWORD=true
