# 数据库配置
DATABASE_URL=mysql://root:@127.0.0.1:3306/novel_db?charset=utf8mb4

# Redis配置
REDIS_URL=redis://127.0.0.1:6379

# 服务器配置
HOST=0.0.0.0
PORT=8080

# JWT配置
JWT_SECRET=change-me-to-a-secure-random-string-in-production
JWT_EXPIRATION_HOURS=720

# 密码哈希配置
PASSWORD_HASH_ITERATIONS=120000

# CORS配置
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174

# DeepSeek（可选）：首次启动可写入 system_settings；日常请在管理后台配置
# http://127.0.0.1:8080/admin/ → AI / 计费配置 → deepseek_api_key / deepseek_base_url
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 邮件配置
SMTP_HOST=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=Novel Writing
SMTP_USE_SSL=true
MAIL_ENABLED=false

# 验证码配置
VERIFY_CODE_TTL_MINUTES=10
VERIFY_CODE_COOLDOWN_SECONDS=60
VERIFY_CODE_MAX_PER_WINDOW=5
VERIFY_CODE_WINDOW_MINUTES=10

# 登录限制
LOGIN_FAILURE_LIMIT=5
LOGIN_FAILURE_WINDOW_MINUTES=15

# 管理后台 http://127.0.0.1:8080/admin/ （axum-admin，独立管理员账号）
ADMIN_ENABLED=true
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin
# 本机 true：启动时同步密码；生产环境务必 false
ADMIN_SYNC_PASSWORD=true

# 日志级别
RUST_LOG=info,novel_backend_rust=debug,sqlx=warn
