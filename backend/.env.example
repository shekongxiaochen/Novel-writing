# DashScope AI
DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen-plus
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
# 复制为 backend/.env 并填写

# CORS：允许访问的前端地址（逗号分隔）
cors_origins="http://localhost:5173,http://localhost:5174"

# MySQL
db_host="127.0.0.1"
db_port=3306
db_name="novel_db"
db_user="root"
db_password="YOUR_PASSWORD"

# Auth / Mail
app_env="development"
auth_token_ttl_hours=720
verify_code_ttl_minutes=10
password_hash_iterations=120000
admin_emails=""
admin_secret_key="change-me-admin-secret"

# SMTP（未配置前可先保持 false，仅打印验证码到后端日志）
mail_enabled=false
smtp_host=""
smtp_port=465
smtp_username=""
smtp_password=""
smtp_from_email=""
smtp_from_name="Novel Writing"
smtp_use_ssl=true
smtp_use_tls=false
