# 本机开发 MySQL / Redis 配置
DATABASE_URL=mysql://root:root@127.0.0.1:3306/novel_db?charset=utf8mb4

REDIS_URL=redis://127.0.0.1:6379

HOST=127.0.0.1
PORT=8080

JWT_SECRET=dev-jwt-secret-change-in-production
JWT_EXPIRATION_HOURS=720

PASSWORD_HASH_ITERATIONS=120000

CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5174

MAIL_ENABLED=false
RUST_LOG=info,novel_backend_rust=debug,sqlx=warn

# 管理后台 http://127.0.0.1:8080/admin/
ADMIN_ENABLED=true
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin
# 本机开发：每次启动把上面密码写入数据库（上线请改为 false）
ADMIN_SYNC_PASSWORD=true
