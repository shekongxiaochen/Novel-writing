{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Novel Writing Assistant",
  "version": "1.0.0",
  "identifier": "com.novelwriting.assistant",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:5174",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "小说写作助手",
        "width": 1440,
        "height": 960,
        "minWidth": 1180,
        "minHeight": 760,
        "backgroundColor": "#0f172a",
        "decorations": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
